import pygame
import random
import math

pygame.init()

WIDTH, HEIGHT = 900, 600
screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("✨ Particle Playground")

clock = pygame.time.Clock()

# ── 파티클 종류 ──────────────────────────────────────────
MODES = ["firework", "sparkle", "smoke", "star"]
current_mode = 0

# ── 폰트 ────────────────────────────────────────────────
font = pygame.font.SysFont("segoeui", 18)
big_font = pygame.font.SysFont("segoeui", 28, bold=True)


# ── 유틸 ────────────────────────────────────────────────
def hsv_to_rgb(h, s, v):
    h = h % 360
    c = v * s
    x = c * (1 - abs((h / 60) % 2 - 1))
    m = v - c
    if h < 60:   r, g, b = c, x, 0
    elif h < 120: r, g, b = x, c, 0
    elif h < 180: r, g, b = 0, c, x
    elif h < 240: r, g, b = 0, x, c
    elif h < 300: r, g, b = x, 0, c
    else:         r, g, b = c, 0, x
    return (int((r+m)*255), int((g+m)*255), int((b+m)*255))


# ── 파티클 클래스 ────────────────────────────────────────
class Particle:
    def __init__(self, x, y, mode, hue_base):
        self.x = x
        self.y = y
        self.mode = mode

        if mode == "firework":
            angle = random.uniform(0, math.pi * 2)
            speed = random.uniform(2, 8)
            self.vx = math.cos(angle) * speed
            self.vy = math.sin(angle) * speed
            self.life = random.randint(50, 90)
            self.max_life = self.life
            self.size = random.uniform(2, 5)
            hue = (hue_base + random.randint(-30, 30)) % 360
            self.color = hsv_to_rgb(hue, 1.0, 1.0)
            self.gravity = 0.12
            self.trail = []

        elif mode == "sparkle":
            angle = random.uniform(0, math.pi * 2)
            speed = random.uniform(0.5, 3)
            self.vx = math.cos(angle) * speed
            self.vy = math.sin(angle) * speed - 1
            self.life = random.randint(30, 60)
            self.max_life = self.life
            self.size = random.uniform(1, 4)
            hue = (hue_base + random.randint(-15, 15)) % 360
            self.color = hsv_to_rgb(hue, 0.3, 1.0)
            self.gravity = 0.03
            self.trail = []

        elif mode == "smoke":
            angle = random.uniform(-0.5, math.pi + 0.5)
            speed = random.uniform(0.3, 1.5)
            self.vx = math.cos(angle) * speed + random.uniform(-0.3, 0.3)
            self.vy = -random.uniform(0.5, 2.0)
            self.life = random.randint(60, 120)
            self.max_life = self.life
            self.size = random.uniform(6, 18)
            gray = random.randint(120, 200)
            self.color = (gray, gray, gray)
            self.gravity = -0.01
            self.trail = []

        elif mode == "star":
            angle = random.uniform(0, math.pi * 2)
            speed = random.uniform(1, 5)
            self.vx = math.cos(angle) * speed
            self.vy = math.sin(angle) * speed
            self.life = random.randint(40, 80)
            self.max_life = self.life
            self.size = random.uniform(2, 6)
            self.color = hsv_to_rgb(hue_base, 0.7, 1.0)
            self.gravity = 0.0
            self.trail = []
            self.spin = random.uniform(-0.2, 0.2)
            self.angle = random.uniform(0, math.pi * 2)

    def update(self):
        self.trail.append((self.x, self.y))
        if len(self.trail) > 8:
            self.trail.pop(0)

        self.x += self.vx
        self.y += self.vy
        self.vy += self.gravity
        self.vx *= 0.98

        if self.mode == "smoke":
            self.size += 0.15
            self.vx += random.uniform(-0.05, 0.05)
        if self.mode == "star":
            self.angle += self.spin

        self.life -= 1

    def draw(self, surf):
        ratio = self.life / self.max_life
        alpha = int(255 * ratio)

        # 트레일
        for i, (tx, ty) in enumerate(self.trail):
            t_ratio = i / max(len(self.trail), 1)
            t_alpha = int(alpha * t_ratio * 0.4)
            t_size = max(1, int(self.size * t_ratio * 0.6))
            r, g, b = self.color
            trail_surf = pygame.Surface((t_size*2+1, t_size*2+1), pygame.SRCALPHA)
            pygame.draw.circle(trail_surf, (r, g, b, t_alpha), (t_size, t_size), t_size)
            surf.blit(trail_surf, (int(tx)-t_size, int(ty)-t_size))

        r, g, b = self.color
        size = max(1, int(self.size))

        if self.mode == "star":
            # 별 모양
            star_surf = pygame.Surface((size*6+1, size*6+1), pygame.SRCALPHA)
            cx, cy = size*3, size*3
            points = []
            for i in range(10):
                a = self.angle + i * math.pi / 5
                rad = size*2.5 if i % 2 == 0 else size*1.2
                points.append((cx + math.cos(a)*rad, cy + math.sin(a)*rad))
            if len(points) >= 3:
                pygame.draw.polygon(star_surf, (r, g, b, alpha), points)
            surf.blit(star_surf, (int(self.x)-size*3, int(self.y)-size*3))

        elif self.mode == "smoke":
            smoke_surf = pygame.Surface((size*2+1, size*2+1), pygame.SRCALPHA)
            pygame.draw.circle(smoke_surf, (r, g, b, min(alpha//3, 80)), (size, size), size)
            surf.blit(smoke_surf, (int(self.x)-size, int(self.y)-size))

        else:
            # 글로우 효과
            for glow_size, glow_alpha in [(size*3, alpha//6), (size*2, alpha//3), (size, alpha)]:
                glow_surf = pygame.Surface((glow_size*2+1, glow_size*2+1), pygame.SRCALPHA)
                pygame.draw.circle(glow_surf, (r, g, b, glow_alpha), (glow_size, glow_size), glow_size)
                surf.blit(glow_surf, (int(self.x)-glow_size, int(self.y)-glow_size))

    def alive(self):
        return self.life > 0


# ── 배경 ────────────────────────────────────────────────
def draw_background(surface, t):
    # 그라디언트 배경
    for y in range(0, HEIGHT, 2):
        ratio = y / HEIGHT
        r = max(0, min(255, int(5 + 10 * math.sin(t * 0.3 + ratio * 2))))
        g = max(0, min(255, int(5 + 8 * math.cos(t * 0.2))))
        b = max(0, min(255, int(20 + 15 * math.sin(t * 0.1 + ratio))))
        pygame.draw.line(surface, (r, g, b), (0, y), (WIDTH, y))
        pygame.draw.line(surface, (r, g, b), (0, y+1), (WIDTH, y+1))

    # 반짝이는 별 배경
    random.seed(42)
    for _ in range(60):
        sx = random.randint(0, WIDTH)
        sy = random.randint(0, HEIGHT)
        brightness = int(100 + 80 * math.sin(t * random.uniform(1, 3) + random.uniform(0, 6)))
        pygame.draw.circle(surface, (brightness, brightness, brightness), (sx, sy), 1)
    random.seed()


def draw_ui(surface, mode_name, particle_count, fps):
    # 모드 표시
    mode_colors = {
        "firework": (255, 120, 80),
        "sparkle":  (180, 255, 200),
        "smoke":    (180, 180, 200),
        "star":     (255, 220, 80),
    }
    color = mode_colors.get(mode_name, (255, 255, 255))

    # 반투명 패널
    panel = pygame.Surface((220, 90), pygame.SRCALPHA)
    pygame.draw.rect(panel, (0, 0, 0, 120), (0, 0, 220, 90), border_radius=12)
    surface.blit(panel, (10, 10))

    title = big_font.render(f"✦ {mode_name.upper()}", True, color)
    surface.blit(title, (20, 18))

    info1 = font.render(f"파티클: {particle_count}", True, (200, 200, 220))
    info2 = font.render(f"FPS: {int(fps)}", True, (200, 200, 220))
    info3 = font.render("Tab: 모드변경  |  클릭: 생성", True, (150, 150, 180))
    surface.blit(info1, (20, 50))
    surface.blit(info2, (110, 50))
    surface.blit(info3, (20, 72))


# ── 메인 루프 ────────────────────────────────────────────
particles = []
running = True
time_val = 0
hue = 0

while running:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False
        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_TAB:
                current_mode = (current_mode + 1) % len(MODES)
            if event.key == pygame.K_ESCAPE:
                running = False
            if event.key == pygame.K_c:
                particles.clear()

    mouse = pygame.mouse.get_pos()
    buttons = pygame.mouse.get_pressed()

    mode_name = MODES[current_mode]
    spawn_count = {"firework": 6, "sparkle": 10, "smoke": 3, "star": 5}

    if buttons[0]:
        hue = (hue + 2) % 360
        for _ in range(spawn_count[mode_name]):
            particles.append(Particle(mouse[0], mouse[1], mode_name, hue))

    time_val += 0.03

    draw_background(screen, time_val)

    for p in particles:
        p.update()
        p.draw(screen)

    particles = [p for p in particles if p.alive()]

    draw_ui(screen, mode_name, len(particles), clock.get_fps())

    pygame.display.flip()
    clock.tick(60)

pygame.quit()